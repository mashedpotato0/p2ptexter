{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "p2ptexter",
  "version": "0.1.1",
  "identifier": "com.p2p.texter",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://127.0.0.1:8081",
    "beforeDevCommand": "python3 -m http.server 8081 --directory /home/mashedpotato/D/projects/p2ptexter/ui"
  },
  "app": {
    "windows": [
      {
        "title": "P2P Texter",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}