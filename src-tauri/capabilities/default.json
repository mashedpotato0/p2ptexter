{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-send-p2p-message",
    "allow-get-my-peer-id",
    "allow-get-nickname",
    "allow-set-nickname",
    "allow-generate-qr",
    "allow-scan-qr",
    "allow-reset-identity",
    "store:default"
  ]
}