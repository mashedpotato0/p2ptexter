{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-capability",
  "description": "enables permissions for the mobile application",
  "platforms": [
    "android",
    "iOS"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-send-p2p-message",
    "allow-get-my-peer-id",
    "allow-get-nickname",
    "allow-set-nickname",
    "allow-get-unread-count",
    "allow-dial-address",
    "allow-dial-peer",
    "allow-reset-identity",
    "store:default"
  ]
}
